# -----------------------------------------------------------------------------
# Core App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voicefirst?schema=public"

# -----------------------------------------------------------------------------
# JWT / Auth
# -----------------------------------------------------------------------------
JWT_SECRET="change-this-to-a-secure-random-string-in-production"
JWT_EXPIRATION_SECONDS=86400

# -----------------------------------------------------------------------------
# 2FA
# -----------------------------------------------------------------------------
TOTP_ENCRYPTION_KEY="change-this-32-char-key-in-prod!"
OTP_EXPIRY_MINUTES=5
RECOVERY_CODES_COUNT=10

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@voicefirst.com"

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# -----------------------------------------------------------------------------
# Messaging: Shared
# -----------------------------------------------------------------------------
# Used to build survey links sent in WhatsApp/SMS.
FRONTEND_BASE_URL="http://localhost:3001"

# Default country prefix applied when a phone number is entered without +country.
MESSAGING_DEFAULT_COUNTRY_CODE="+1"

# Queue worker tuning (DB-backed queue poller)
MESSAGING_QUEUE_POLL_MS=5000
MESSAGING_QUEUE_BATCH_SIZE=10

# Duplicate suppression window to avoid accidental repeated sends
MESSAGING_DUPLICATE_WINDOW_MS=120000

# -----------------------------------------------------------------------------
# Messaging: WhatsApp Cloud API (Meta)
# -----------------------------------------------------------------------------
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_API_VERSION="v21.0"

# Must match your Meta webhook verify token
WHATSAPP_WEBHOOK_VERIFY_TOKEN="change-me"

# -----------------------------------------------------------------------------
# Messaging: SMS Fallback (Twilio)
# -----------------------------------------------------------------------------
# If these are left empty, SMS provider runs in mock mode for local testing.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
